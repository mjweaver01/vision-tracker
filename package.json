{
  "name": "vision-tracker",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot --watch src/server/index.ts",
    "start": "NODE_ENV=production bun run src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "cert:generate": "./scripts/generate-cert.sh",
    "build:client": "vite build",
    "dev:client": "vite dev",
    "build:mobile": "vite build && npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/bun": "latest",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "bun-plugin-tailwind": "^0.1.2",
    "tailwindcss": "^4",
    "typescript": "^5.3.0",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@mediapipe/tasks-vision": "^0.10.32",
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0"
  }
}
